{
  "enabled": true,
  "name": "Post Task: Commit & Push",
  "description": "When you complete any task in tasks.md and check it as completed, please commit and push.",
  "version": "2",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Task completed. Please commit and push using these steps:\n1. Run `pnpm type-check` and fix any errors\n2. Run `pnpm test` and fix any failures (run packages sequentially, not in parallel)\n3. If API source was changed, run `cd packages/infra && pnpm --filter @vote-board-game/api build && pnpm test -- -u` to update snapshots\n4. Commit with conventional commit message including task number\n5. Push to current branch (never push to main)\n\nIMPORTANT: Do NOT run multiple test suites in parallel. Run them one at a time to avoid high CPU/memory usage."
  },
  "workspaceFolderName": "vote-board-game",
  "shortName": "post-task-lint-test-push"
}

# E2E Test Environment Variables (Local Execution)
# Copy this file to .env.local and fill in the values
#
# Usage:
#   pnpm --filter @vote-board-game/web test:e2e           # all tests (chromium)
#   pnpm --filter @vote-board-game/web test:e2e:game       # game tests only
#   pnpm --filter @vote-board-game/web test:e2e:headed     # with browser UI
#   pnpm --filter @vote-board-game/web test:e2e:ui         # Playwright UI mode
#
# AWS credentials setup:
#   Ensure AWS credentials are configured via AWS CLI profile or environment variables.
#   E2E tests need DynamoDB and Cognito access.
#   Example: aws sso login --profile your-dev-profile
#            export AWS_PROFILE=your-dev-profile

# Frontend URL (Vercel deployment URL)
BASE_URL=https://vote-board-game-web.vercel.app

# API URL (from CloudFormation stack output: ApiUrl)
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.ap-northeast-1.amazonaws.com

# App URL for OGP image generation
NEXT_PUBLIC_APP_URL=https://vote-board-game-web.vercel.app

# DynamoDB Table Name (from CloudFormation stack output: TableName)
DYNAMODB_TABLE_NAME=vbg-dev-dynamodb-main

# Cognito User Pool ID (from CloudFormation stack output: UserPoolId)
USER_POOL_ID=ap-northeast-1_XXXXXXXXX
COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX

# Cognito Client ID (from CloudFormation stack output: UserPoolClientId)
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Test User Credentials (required for authenticated E2E tests)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# AWS Region
AWS_REGION=ap-northeast-1

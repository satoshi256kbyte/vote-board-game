# E2E Test Environment Variables
# Copy this file to .env.local and fill in the values

# Frontend URL
BASE_URL=http://localhost:3000

# API URL (from CloudFormation stack output)
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.ap-northeast-1.amazonaws.com

# DynamoDB Table Name (from CloudFormation stack output)
DYNAMODB_TABLE_NAME=vbg-dev-dynamodb-main

# Cognito User Pool ID (from CloudFormation stack output)
USER_POOL_ID=ap-northeast-1_XXXXXXXXX
COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX

# Cognito Client ID (from CloudFormation stack output)
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Test User Credentials (optional, for authenticated tests)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPassword123

# AWS Region
AWS_REGION=ap-northeast-1

# CI flag (set to true in CI environment)
CI=false
